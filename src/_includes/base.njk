<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>{{ title | safe }} · {{ date | ptDateISO }}</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
<link rel="stylesheet" href="{{ '/assets/lesson.css' | url }}" />
</head>
<body data-storage-key="{{ date | ptStorageKey }}">
<a class="skip-link" href="#conteudo">Saltar para o conteúdo</a>

<header>
  <svg class="header-sardine" viewBox="0 0 140 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <!-- Tail fin -->
    <path d="M 5 10 L 28 25 L 5 40 L 14 25 Z" fill="#5a738a"/>
    <!-- Body -->
    <path d="M 22 25 Q 65 6 122 22 Q 130 25 122 28 Q 65 44 22 25 Z" fill="#7e9cb6"/>
    <!-- Belly highlight -->
    <path d="M 28 28 Q 65 41 118 30 Q 65 37 28 28 Z" fill="#c4d4e0"/>
    <!-- Lateral line -->
    <path d="M 38 25 Q 75 23 110 26" stroke="#3d556e" stroke-width="1" fill="none" opacity=".45"/>
    <!-- Top fin -->
    <path d="M 60 13 L 72 4 L 72 14 Z" fill="#5a738a"/>
    <!-- Pelvic fin -->
    <path d="M 66 37 L 72 43 L 76 38 Z" fill="#5a738a"/>
    <!-- Gill -->
    <path d="M 106 18 Q 108 25 106 32" stroke="#3d556e" stroke-width="0.9" fill="none" opacity=".5"/>
    <!-- Eye -->
    <circle cx="115" cy="22" r="2.2" fill="#1a2530"/>
    <circle cx="114.4" cy="21.3" r="0.7" fill="#fff"/>
    <!-- Mouth -->
    <path d="M 122 26 Q 126 27 122 28" stroke="#3d556e" stroke-width="0.9" fill="none" opacity=".5"/>
  </svg>
  <svg class="header-pastel" viewBox="0 0 100 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <!-- Pastry cup body -->
    <path d="M 20 28 L 22 72 Q 50 78 78 72 L 80 28 Z" fill="#b87a3e"/>
    <!-- Fluted ridges -->
    <path d="M 28 29 L 29 74" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 37 29 L 38 76" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 50 29 L 50 77" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 63 29 L 62 76" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 72 29 L 71 74" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <!-- Custard top -->
    <ellipse cx="50" cy="28" rx="30" ry="6" fill="#f5c54e"/>
    <ellipse cx="42" cy="25.5" rx="14" ry="1.8" fill="#fae29a" opacity=".55"/>
    <!-- Burnt caramelized spots -->
    <ellipse cx="38" cy="27" rx="4" ry="1.8" fill="#2a1606"/>
    <ellipse cx="56" cy="29" rx="5" ry="2.2" fill="#2a1606"/>
    <ellipse cx="68" cy="27" rx="3" ry="1.5" fill="#2a1606"/>
    <ellipse cx="46" cy="30" rx="2.5" ry="1" fill="#2a1606" opacity=".7"/>
  </svg>
  <div class="header-inner">
    <a class="back" href="{{ '/' | url }}">← Voltar ao início</a>
    <p class="lesson-date">{{ date | ptDateLong }}</p>
    <h1>{{ title | safe }}</h1>
    <p class="subtitle">{{ subtitle | safe }}</p>
  </div>
</header>

{# Section jump-nav — populated by lesson.js from each section's <h2>; stays empty (and hidden) when a page has no sections. #}
<nav class="section-nav" id="sectionNav" aria-label="Secções da aula"></nav>

<main class="wrap" id="conteudo">

  {# Auto prev/next from the lesson collection (oldest → newest). Adding a lesson updates neighbours automatically. #}
  {% set prevItem = collections.lesson | getPreviousCollectionItem(page) %}
  {% set nextItem = collections.lesson | getNextCollectionItem(page) %}

  <nav class="pager" aria-label="Navegação entre aulas">
    {% if prevItem %}
    <a class="pager-link prev" href="{{ prevItem.url | url }}">
      <span class="pager-dir">← Anterior</span>
      <span class="pager-title">{{ prevItem.date | ptDateShort }}</span>
    </a>
    {% else %}
    <span class="pager-link prev disabled">
      <span class="pager-dir">← Anterior</span>
      <span class="pager-title">—</span>
    </span>
    {% endif %}
    {% if nextItem %}
    <a class="pager-link next" href="{{ nextItem.url | url }}">
      <span class="pager-dir">Próxima →</span>
      <span class="pager-title">{{ nextItem.date | ptDateShort }}</span>
    </a>
    {% else %}
    <span class="pager-link next disabled">
      <span class="pager-dir">Próxima →</span>
      <span class="pager-title">Em breve</span>
    </span>
    {% endif %}
  </nav>

  {{ content | safe }}

  <nav class="pager" aria-label="Navegação entre aulas">
    {% if prevItem %}
    <a class="pager-link prev" href="{{ prevItem.url | url }}">
      <span class="pager-dir">← Anterior</span>
      <span class="pager-title">{{ prevItem.date | ptDateShort }}</span>
    </a>
    {% else %}
    <span class="pager-link prev disabled">
      <span class="pager-dir">← Anterior</span>
      <span class="pager-title">—</span>
    </span>
    {% endif %}
    {% if nextItem %}
    <a class="pager-link next" href="{{ nextItem.url | url }}">
      <span class="pager-dir">Próxima →</span>
      <span class="pager-title">{{ nextItem.date | ptDateShort }}</span>
    </a>
    {% else %}
    <span class="pager-link next disabled">
      <span class="pager-dir">Próxima →</span>
      <span class="pager-title">Em breve</span>
    </span>
    {% endif %}
  </nav>

  {# Worksheet lightbox — chrome shared by every lesson; the script no-ops when a lesson has no gallery. #}
  <div class="lightbox" id="lightbox" role="dialog" aria-modal="true" aria-label="Ficha de trabalho ampliada">
    <button type="button" class="lb-close" id="lbClose" aria-label="Fechar">✕</button>
    <button type="button" class="lb-nav lb-prev" id="lbPrev" aria-label="Página anterior">‹</button>
    <img id="lbImg" src="" alt="">
    <button type="button" class="lb-nav lb-next" id="lbNext" aria-label="Página seguinte">›</button>
    <span class="lb-cap" id="lbCap"></span>
  </div>

  <footer>
    📝 {{ footerProvenance or "Lição gerada a partir da aula real com a Mariana" }} · {{ date | ptDateLong }}
    <p class="made-with">Feito com ❤️ em Portugal<span class="sep">·</span>© Magda Kowalska</p>
  </footer>
</main>

<script src="{{ '/assets/lesson.js' | url }}"></script>
</body>
</html>
