<!DOCTYPE html>
<html lang="pt-PT">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<title>As Minhas Aulas de Português</title>
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Hanken+Grotesk:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
<style>
  :root {
    --green: #1B5E20;
    --gold-text: #8a5e00;       /* WCAG-safe on white and on --gold-light */
    --gold-deep: #5c3d00;       /* For strong text on --gold-light */
    --gold-light: #fdf3dc;
    --gold-border: #f0dca8;
    --ink: #20302a;
    --muted: #5b6b63;
    --paper: #fcfbf7;
    --card: #ffffff;
    --border: #e3e0d6;
    --shadow: 0 1px 2px rgba(27,94,32,.05);
    --ease-out-soft: cubic-bezier(.2,.8,.2,1);
    /* spacing scale */
    --space-2: 8px;
    --space-3: 12px;
    --space-4: 16px;
    --space-5: 24px;
    --space-6: 32px;
    --space-7: 48px;
    --space-8: 64px;
    --space-9: 96px;
  }
  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body {
    margin: 0;
    font-family: 'Hanken Grotesk', system-ui, -apple-system, sans-serif;
    color: var(--ink);
    background: var(--paper);
    line-height: 1.6;
    font-size: 1.0625rem;        /* 17px at the user's default; respects browser font-size setting */
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }
  .wrap { max-width: 960px; margin: 0 auto; padding: 0 20px var(--space-9); }

  /* Header */
  header {
    background: var(--green);
    color: #fff;
    padding: clamp(48px, 8vw, 80px) 0 clamp(40px, 6vw, 64px);
    position: relative;
    overflow: hidden;
  }
  header::after {
    content: "🇵🇹";
    position: absolute;
    right: -10px; bottom: -34px;
    font-size: 170px; line-height: 1; opacity: .14;
    transform: rotate(-8deg);
    pointer-events: none;
  }
  .header-pastel {
    position: absolute;
    right: 175px; bottom: 8px;
    width: 150px; height: auto;
    opacity: .22;
    transform: rotate(-6deg);
    pointer-events: none;
  }
  .header-sardine {
    position: absolute;
    right: 335px; bottom: 22px;
    width: 150px; height: auto;
    opacity: .2;
    transform: rotate(-8deg);
    pointer-events: none;
  }
  @media (max-width: 640px) {
    header::after { font-size: 120px; bottom: -22px; }
    .header-pastel { width: 105px; right: 120px; bottom: 6px; }
    .header-sardine { display: none; }
  }
  .header-inner { max-width: 960px; margin: 0 auto; padding: 0 20px; position: relative; z-index: 1; }
  h1 {
    font-family: 'EB Garamond', Georgia, serif; font-weight: 600;
    font-size: clamp(30px, 5vw, 46px); line-height: 1.15;
    margin: 0 0 14px;
    text-wrap: balance;
  }
  .subtitle { font-size: 1.0625rem; opacity: .92; max-width: 60ch; margin: 0; text-wrap: pretty; }
  .subtitle .name { font-family: 'EB Garamond', Georgia, serif; font-style: italic; font-weight: 500; font-size: 1.15em; letter-spacing: .005em; }

  /* Section heads */
  .section-head { display: flex; align-items: baseline; gap: var(--space-3); flex-wrap: wrap; margin: var(--space-8) 0 var(--space-2); }
  .section-head h2 { font-family: 'EB Garamond', Georgia, serif; font-size: clamp(22px, 2.6vw, 28px); font-weight: 600; color: var(--ink); margin: 0; text-wrap: balance; letter-spacing: -0.01em; }
  .section-head .count { font-size: 13px; color: var(--muted); font-weight: 500; }
  .section-sub { color: var(--muted); margin: 0 0 var(--space-5); font-size: 15px; max-width: 60ch; text-wrap: pretty; }
  /* Keep on one line on wide screens; wrap normally on mobile to avoid horizontal overflow */
  .section-sub.nowrap-wide { max-width: none; }
  @media (min-width: 700px) { .section-sub.nowrap-wide { white-space: nowrap; } }

  /* Mariana lessons — vertical stack of wide horizontal tiles */
  .lessons-list { display: flex; flex-direction: column; gap: var(--space-3); }
  .lesson {
    display: grid; grid-template-columns: 1fr auto; gap: var(--space-5);
    align-items: center;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: var(--space-4) var(--space-5);
    box-shadow: var(--shadow);
    text-decoration: none; color: inherit;
    transition: border-color .18s var(--ease-out-soft), box-shadow .18s var(--ease-out-soft);
  }
  .lesson:hover { border-color: var(--accent, var(--green)); box-shadow: 0 2px 6px rgba(27,94,32,.08); }
  .lesson .date {
    font-size: 13px; color: var(--muted); margin: 0 0 4px;
    font-variant-numeric: tabular-nums;
  }
  .lesson .date .status {
    color: var(--accent, var(--green)); font-weight: 600;
  }
  .lesson h3 { font-family: 'EB Garamond', Georgia, serif; font-size: 21px; font-weight: 600; margin: 0 0 4px; line-height: 1.25; color: var(--ink); text-wrap: balance; }
  .lesson .topics { font-size: 14.5px; color: var(--muted); margin: 0; max-width: 70ch; text-wrap: pretty; }
  .lesson .go {
    font-weight: 700; font-size: 14px; color: var(--accent, var(--green)); white-space: nowrap;
    display: inline-flex; align-items: center; gap: var(--space-2);
  }
  .lesson .go .arrow { transition: transform .18s var(--ease-out-soft); display: inline-block; }
  .lesson:hover .go .arrow { transform: translateX(4px); }
  @media (max-width: 520px) {
    .lesson { grid-template-columns: 1fr; gap: var(--space-3); }
  }

  /* Course callout — featured singleton, not a grid */
  .course-callout {
    display: grid; grid-template-columns: 1fr auto; gap: var(--space-5);
    align-items: center;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 14px; padding: var(--space-5) var(--space-5);
    box-shadow: var(--shadow);
    text-decoration: none; color: inherit;
    transition: border-color .18s var(--ease-out-soft), box-shadow .18s var(--ease-out-soft);
  }
  .course-callout:hover { border-color: var(--green); box-shadow: 0 2px 6px rgba(27,94,32,.08); }
  .course-callout .meta {
    font-size: 14px; color: var(--muted); margin: 0 0 var(--space-2);
    font-variant-numeric: tabular-nums;
  }
  .course-callout .meta .status {
    color: var(--green); font-weight: 600;
  }
  .course-callout h3 { font-family: 'EB Garamond', Georgia, serif; font-size: 22px; font-weight: 600; margin: 0 0 var(--space-2); line-height: 1.2; color: var(--ink); text-wrap: balance; }
  .course-callout .topics { font-size: 15px; color: var(--muted); margin: 0; max-width: 56ch; text-wrap: pretty; }
  .course-callout .go {
    font-weight: 700; font-size: 14px; color: var(--green); white-space: nowrap;
    display: inline-flex; align-items: center; gap: var(--space-2);
  }
  .course-callout .arrow { transition: transform .18s var(--ease-out-soft); display: inline-block; }
  .course-callout:hover .arrow { transform: translateX(4px); }
  @media (max-width: 520px) {
    .course-callout { grid-template-columns: 1fr; }
  }

  /* Referência & recursos — in-house cheat sheet + external links as rectangular tiles in one row */
  .ref-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: var(--space-3); }
  .ref-card {
    display: flex; flex-direction: column;
    background: var(--card); border: 1px solid var(--border);
    border-radius: 12px; padding: var(--space-5) var(--space-4);
    box-shadow: var(--shadow);
    text-decoration: none; color: inherit;
    transition: border-color .18s var(--ease-out-soft), box-shadow .18s var(--ease-out-soft);
  }
  .ref-card:hover { border-color: var(--green); box-shadow: 0 2px 6px rgba(27,94,32,.08); }
  .ref-card h3 { font-family: 'EB Garamond', Georgia, serif; font-size: 19px; font-weight: 600; margin: 0 0 var(--space-2); line-height: 1.2; color: var(--ink); text-wrap: balance; }
  .ref-card .host { font-size: 13px; color: var(--muted); margin: 0; text-wrap: pretty; }
  .ref-card .go {
    margin-top: auto; padding-top: var(--space-5);
    font-weight: 700; font-size: 14px; color: var(--green); white-space: nowrap;
    display: inline-flex; align-items: center; gap: var(--space-2);
  }
  .ref-card .arrow { transition: transform .18s var(--ease-out-soft); display: inline-block; }
  .ref-card.is-internal:hover .arrow { transform: translateX(4px); }
  .ref-card.is-external:hover .arrow { transform: translate(2px, -2px); }
  @media (max-width: 720px) {
    .ref-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 400px) {
    .ref-grid { grid-template-columns: 1fr; }
  }

  /* Visually hidden but available to assistive tech */
  .sr-only {
    position: absolute; width: 1px; height: 1px;
    padding: 0; margin: -1px; overflow: hidden;
    clip: rect(0, 0, 0, 0); white-space: nowrap; border: 0;
  }

  /* Skip link — hidden until a keyboard user focuses it, then drops into view */
  .skip-link {
    position: absolute; left: 12px; top: -56px; z-index: 1000;
    background: var(--green); color: #fff;
    padding: 10px 16px; border-radius: 0 0 10px 10px;
    font-weight: 700; font-size: 14px; text-decoration: none;
    transition: top .15s var(--ease-out-soft);
  }
  .skip-link:focus-visible { top: 0; outline: 2px solid #fff; outline-offset: 2px; }

  footer {
    text-align: center;
    color: var(--muted);
    margin-top: var(--space-8);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-3);
  }
  footer .made-with {
    font-size: 14px;
    margin: 0;
  }
  footer .made-with .sep {
    margin: 0 0.6em;
    opacity: 0.5;
  }

  /* Focus rings for keyboard users — solid green so it reads as "selected", not as hover */
  .lesson:focus-visible,
  .course-callout:focus-visible,
  .ref-card:focus-visible {
    outline: 2px solid var(--green);
    outline-offset: 3px;
  }
  @media (prefers-reduced-motion: reduce) {
    .course-callout .arrow, .lesson .go .arrow, .ref-card .arrow,
    .course-callout, .lesson, .ref-card { transition: none; }
    .course-callout:hover .arrow, .lesson:hover .go .arrow, .ref-card:hover .arrow { transform: none; }
    .skip-link { transition: none; }
    html { scroll-behavior: auto; }
  }
</style>
</head>
<body>
<a class="skip-link" href="#conteudo">Saltar para o conteúdo</a>

<header>
  <svg class="header-sardine" viewBox="0 0 140 50" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <!-- Tail fin -->
    <path d="M 5 10 L 28 25 L 5 40 L 14 25 Z" fill="#5a738a"/>
    <!-- Body -->
    <path d="M 22 25 Q 65 6 122 22 Q 130 25 122 28 Q 65 44 22 25 Z" fill="#7e9cb6"/>
    <!-- Belly highlight -->
    <path d="M 28 28 Q 65 41 118 30 Q 65 37 28 28 Z" fill="#c4d4e0"/>
    <!-- Lateral line -->
    <path d="M 38 25 Q 75 23 110 26" stroke="#3d556e" stroke-width="1" fill="none" opacity=".45"/>
    <!-- Top fin -->
    <path d="M 60 13 L 72 4 L 72 14 Z" fill="#5a738a"/>
    <!-- Pelvic fin -->
    <path d="M 66 37 L 72 43 L 76 38 Z" fill="#5a738a"/>
    <!-- Gill -->
    <path d="M 106 18 Q 108 25 106 32" stroke="#3d556e" stroke-width="0.9" fill="none" opacity=".5"/>
    <!-- Eye -->
    <circle cx="115" cy="22" r="2.2" fill="#1a2530"/>
    <circle cx="114.4" cy="21.3" r="0.7" fill="#fff"/>
    <!-- Mouth -->
    <path d="M 122 26 Q 126 27 122 28" stroke="#3d556e" stroke-width="0.9" fill="none" opacity=".5"/>
  </svg>
  <svg class="header-pastel" viewBox="0 0 100 80" xmlns="http://www.w3.org/2000/svg" aria-hidden="true" focusable="false">
    <!-- Pastry cup body -->
    <path d="M 20 28 L 22 72 Q 50 78 78 72 L 80 28 Z" fill="#b87a3e"/>
    <!-- Fluted ridges -->
    <path d="M 28 29 L 29 74" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 37 29 L 38 76" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 50 29 L 50 77" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 63 29 L 62 76" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <path d="M 72 29 L 71 74" stroke="#7a4c1a" stroke-width="0.9" opacity=".55" fill="none"/>
    <!-- Custard top -->
    <ellipse cx="50" cy="28" rx="30" ry="6" fill="#f5c54e"/>
    <ellipse cx="42" cy="25.5" rx="14" ry="1.8" fill="#fae29a" opacity=".55"/>
    <!-- Burnt caramelized spots -->
    <ellipse cx="38" cy="27" rx="4" ry="1.8" fill="#2a1606"/>
    <ellipse cx="56" cy="29" rx="5" ry="2.2" fill="#2a1606"/>
    <ellipse cx="68" cy="27" rx="3" ry="1.5" fill="#2a1606"/>
    <ellipse cx="46" cy="30" rx="2.5" ry="1" fill="#2a1606" opacity=".7"/>
  </svg>
  <div class="header-inner">
    <h1>As Minhas Aulas de Português</h1>
    <p class="subtitle">Bem-vinda, <span class="name">Magda</span>. Aqui estão todas as tuas lições, prontas para começar ou continuar de onde paraste.</p>
  </div>
</header>

<main class="wrap" id="conteudo">

  <!-- REFERÊNCIA & RECURSOS — in-house cheat sheet + external study tools as rectangular tiles -->
  <div class="section-head">
    <h2>Referência rápida</h2>
    <span class="count">a cábula de verbos e três sites de consulta</span>
  </div>
  <p class="section-sub nowrap-wide">Conjugações, traduções e definições, para tirares dúvidas em segundos.</p>

  <div class="ref-grid">
    <a class="ref-card is-internal" href="verbos.html">
      <h3>Verbos &amp; Conjugações</h3>
      <p class="host">Presente · perfeito · imperfeito · futuro · condicional</p>
      <span class="go">Abrir <span class="arrow">→</span></span>
    </a>
    <a class="ref-card is-external" href="https://www.deepl.com/pt-PT/translator" target="_blank" rel="noopener noreferrer">
      <h3>DeepL <span lang="en">Translator</span></h3>
      <p class="host">deepl.com</p>
      <span class="go">Abrir<span class="sr-only"> em nova janela</span> <span class="arrow" aria-hidden="true">↗</span></span>
    </a>
    <a class="ref-card is-external" href="https://dicionario.priberam.org/" target="_blank" rel="noopener noreferrer">
      <h3>Dicionário Priberam</h3>
      <p class="host">dicionario.priberam.org</p>
      <span class="go">Abrir<span class="sr-only"> em nova janela</span> <span class="arrow" aria-hidden="true">↗</span></span>
    </a>
    <a class="ref-card is-external" href="https://european-portuguese.info/conjugator/ser" target="_blank" rel="noopener noreferrer">
      <h3>Conjugador de Português Europeu</h3>
      <p class="host">european-portuguese.info</p>
      <span class="go">Abrir<span class="sr-only"> em nova janela</span> <span class="arrow" aria-hidden="true">↗</span></span>
    </a>
  </div>

  <!-- AULAS COM A MARIANA -->
  <div class="section-head">
    <h2>Aulas com a Mariana</h2>
    <span class="count">aulas reais transformadas em guias de estudo</span>
  </div>
  <p class="section-sub">Da mais recente para a mais antiga.</p>

  <div class="lessons-list">

{%- for lesson in collections.lesson | reverse %}
    <a class="lesson" style="--accent: {{ lesson.data.accent }}" href="{{ lesson.url | url }}"
       data-keys="{{ lesson.date | ptStorageKey }}">
      <div>
        <p class="date"><time datetime="{{ lesson.date | ptDateISO }}">{{ lesson.date | ptDateLong }}</time></p>
        <h3>{{ lesson.data.cardTitle | safe }}</h3>
        <p class="topics">{{ lesson.data.topics | safe }}</p>
      </div>
      <span class="go">Abrir <span class="arrow">→</span></span>
    </a>
{% endfor %}
  </div>

  <!-- CURSO ESTRUTURADO — driven by the curriculo collection (ordered by lessonNumber) -->
  <div class="section-head">
    <h2>Curso estruturado A2 → B1</h2>
    <span class="count">{{ collections.curriculo.length }} {% if collections.curriculo.length == 1 %}lição{% else %}lições{% endif %} · mais a chegar</span>
  </div>
  <p class="section-sub">O plano completo, lição a lição, para construíres bases sólidas desde a raiz.</p>

  <div class="lessons-list">
{%- for l in collections.curriculo %}
    <a class="course-callout" style="--accent: {{ l.data.accent }}" href="{{ l.url | url }}" data-keys="{{ l.data.lessonNumber | ptLessonKey }}">
      <div>
        <p class="meta">Lição {{ l.data.lessonNumber }} · {{ l.data.level }}</p>
        <h3>{{ l.data.cardTitle | safe }}</h3>
        <p class="topics">{{ l.data.topics | safe }}</p>
      </div>
      <span class="go">Abrir <span class="arrow">→</span></span>
    </a>
{%- endfor %}
  </div>

  <footer>
    <p class="made-with">Feito com ❤️ em Portugal<span class="sep">·</span>© Magda Kowalska</p>
  </footer>
</main>

<script>
  (function(){
    function isStarted(el){
      const keys = (el.dataset.keys || '').split(',').map(s => s.trim()).filter(Boolean);
      for (const k of keys){
        if (localStorage.getItem(k) !== null) return true;
        for (let i = 0; i < localStorage.length; i++){
          if (localStorage.key(i).startsWith(k)) return true;
        }
      }
      return false;
    }

    // Mark Mariana lesson cards as começada inline with the date line.
    const lessons = Array.from(document.querySelectorAll('.lesson[data-keys]'));
    lessons.forEach(card => {
      if (!isStarted(card)) return;
      const dateLine = card.querySelector('.date');
      if (!dateLine) return;
      const status = document.createElement('span');
      status.className = 'status';
      status.textContent = ' · começada';
      dateLine.appendChild(status);
      const title = card.querySelector('h3');
      if (title) card.setAttribute('aria-label', title.textContent.trim() + ', aula começada');
    });

    // Mark each started course callout, and shift its CTA verb.
    const courseCallouts = Array.from(document.querySelectorAll('.course-callout[data-keys]'));
    courseCallouts.forEach(courseCallout => {
      if (!isStarted(courseCallout)) return;
      const cta = courseCallout.querySelector('.go');
      if (cta) cta.firstChild.textContent = 'Continuar ';
      const meta = courseCallout.querySelector('.meta');
      if (meta) {
        const status = document.createElement('span');
        status.className = 'status';
        status.textContent = ' · começada';
        meta.appendChild(status);
      }
      const title = courseCallout.querySelector('h3');
      if (title) courseCallout.setAttribute('aria-label', title.textContent.trim() + ', começada');
    });
  })();
</script>
</body>
</html>
